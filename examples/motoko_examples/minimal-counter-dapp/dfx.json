{
    "canisters": {
        "minimal_dapp": {
            "type": "custom",
            "build": "python -m kybra minimal_dapp src/minimal_dapp/main.py src/minimal_dapp/main.did",
            "candid": "src/minimal_dapp/main.did",
            "wasm": ".dfx/kybra/minimal_dapp/target/wasm32-unknown-unknown/release/minimal_dapp.wasm.gz",
            "declarations": {
                "output": "test/dfx_generated/minimal_dapp",
                "node_compatibility": true
            }
        },
        "minimal_dapp_assets": {
            "dependencies": ["minimal_dapp"],
            "frontend": {
                "entrypoint": "src/minimal_dapp_assets/src/index.html"
            },
            "source": [
                "src/minimal_dapp_assets/assets",
                "dist/minimal_dapp_assets/"
            ],
            "type": "assets"
        }
    }
}
